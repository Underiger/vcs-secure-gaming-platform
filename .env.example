# ============================================================
# Virtual Casino Sandbox — 環境變數範本
#
# 【開發環境】
#   cp .env.example .env
#   bash scripts/gen-secrets.sh
#
# 【生產環境（Raspberry Pi 4 arm64）】
#   cp .env.example .env.production
#   nano .env.production                         # 修改所有 change_me + NODE_ENV=production
#   bash scripts/gen-secrets.sh .env.production   # 自動填入機密值
#
# .env / .env.production 已列入 .gitignore，嚴禁提交
# ============================================================

# --- App ---
# 開發環境：development；生產環境：production
NODE_ENV=development
PORT=3000
# 日誌等級：fatal/error/warn/info/debug/trace（生產建議 warn 或 info）
LOG_LEVEL=info
# node:cluster fork 數（1–4；Pi 4 建議 2，02_TDD §7：×2 workers 各 512 MB）
WORKERS=2
SOCKET_MAX_CONNECTIONS=200

# --- PostgreSQL ---
POSTGRES_USER=casino
POSTGRES_PASSWORD=change_me
# 開發：casino_dev；生產：casino_prod（docker-compose.arm64.yml 預設 casino_prod）
POSTGRES_DB=casino_dev
# 開發本機 port（開發用 docker-compose.yml 暴露；生產 docker-compose.arm64.yml 不暴露）
POSTGRES_PORT=5432

# --- Prisma 連線字串 ---
# 開發（local PostgreSQL，由 docker-compose 啟動；hostname = localhost）：
DATABASE_URL=postgresql://casino:change_me@localhost:5432/casino_dev?schema=public
#
# 生產（docker-compose.arm64.yml；hostname 使用 Docker 服務名稱 "postgres"）：
# DATABASE_URL=postgresql://casino:change_me@postgres:5432/casino_prod?schema=public
#
# 開發替代方案（SQLite，免 Docker）：
# DATABASE_URL=file:./dev.sqlite

# --- Redis ---
REDIS_PORT=6379
# 開發：redis://localhost:6379（dev compose 不啟用 AUTH，localhost 綁定）
REDIS_URL=redis://localhost:6379
# 生產（docker-compose.arm64.yml；hostname 使用 Docker 服務名稱 "redis"，並啟用 --requirepass）：
# REDIS_URL=redis://:YOUR_REDIS_PASSWORD@redis:6379
# Redis AUTH 密碼（縱深防禦，見 0615_SECURITY_REPORT §三.1）。
# 由 scripts/gen-secrets.sh 自動產生，並在 REDIS_URL 指向 hostname=redis 時自動注入。
REDIS_PASSWORD=change_me

# --- 認證 / 安全（由 scripts/gen-secrets.sh 自動產生）---
# JWT HS256 簽章金鑰（≥ 64 hex chars；128 hex = 64 bytes 建議長度）
JWT_SECRET=change_me
# Access Token 存活時間（15m 適合生產；開發可放寬至 1h）
JWT_ACCESS_TTL=15m
# Refresh Token 存活天數（旋轉式）
REFRESH_TOKEN_TTL_DAYS=7
# AES-256-GCM 金鑰（恰 64 hex chars = 32 bytes；TOTP secret 加密用）
AES_256_GCM_KEY=change_me

# --- Admin 初始帳號（M02 seed 使用，首次部署後建議更改）---
ADMIN_USERNAME=admin
ADMIN_INITIAL_PASSWORD=change_me

# --- 異常通知（可選；M24 使用）---
# Slack Incoming Webhook URL 或自訂端點（留空則不發送通知）
ALERT_WEBHOOK_URL=

# --- Telegram 2FA 推播（可選）---
# 任一留空即功能關閉，admin 高危操作 2FA 重驗退回手動輸入 TOTP（行為與未設定前完全一致）。
# 啟用後 ReverifyDialog 會自動推播核准請求到下方 chat id，點按鈕即可取代手動輸入驗證碼。
# Bot token：跟 @BotFather 申請（/newbot），格式 123456789:ABCdefGHIjklmNOpqrstUVwxyz
TELEGRAM_BOT_TOKEN=
# 唯一授權核准的 chat id（數字字串）：必須是管理員本人「私訊」bot 取得的個人
# chat id（正數）——核准驗證比對的是按鈕點擊者的 from.id，私聊時 from.id 才會
# 等於 chat.id；切勿填群組 chat id（通常是負數），否則 sendMessage 會回
# "chat not found"，且即使送達也永遠核准不了。
# 1. 先用 Telegram 帳號私訊你的 bot 一則任意訊息（不是把 bot 加進群組）
# 2. 查詢（取最後一筆訊息的 chat.id）：
#    curl -s "https://api.telegram.org/bot<TOKEN>/getUpdates" | python3 -c \
#      "import json,sys; print(json.load(sys.stdin)['result'][-1]['message']['chat']['id'])"
TELEGRAM_ADMIN_CHAT_ID=

# ============================================================
# 生產環境（.env.production）額外設定清單
# ============================================================
# 以下為生產環境需調整的值（複製為 .env.production 後取消注釋並填入）：
#
# NODE_ENV=production
# WORKERS=2
# LOG_LEVEL=warn
# POSTGRES_DB=casino_prod
# DATABASE_URL=postgresql://casino:YOUR_SECURE_PG_PASSWORD@postgres:5432/casino_prod?schema=public
# REDIS_URL=redis://:YOUR_REDIS_PASSWORD@redis:6379
# REDIS_PASSWORD=（執行 scripts/gen-secrets.sh 自動產生，並注入上方 REDIS_URL）
# JWT_SECRET=（執行 scripts/gen-secrets.sh 自動產生）
# AES_256_GCM_KEY=（執行 scripts/gen-secrets.sh 自動產生）
# ADMIN_INITIAL_PASSWORD=（執行 scripts/gen-secrets.sh 自動產生）
# ALERT_WEBHOOK_URL=https://hooks.slack.com/...（可選）
# TELEGRAM_BOT_TOKEN=（@BotFather 申請，可選）
# TELEGRAM_ADMIN_CHAT_ID=（可選；兩者任一留空即 2FA 退回手動輸入 TOTP）
