{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "description": "Virtual Casino Sandbox — Fastify API + Socket.IO + BullMQ",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/cluster.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cluster.js",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit:balance": "tsx scripts/audit-balance.ts",
    "postinstall": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio",
    "prisma:push:sqlite": "prisma db push --schema prisma/schema.sqlite.prisma",
    "prisma:generate:sqlite": "prisma generate --schema prisma/schema.sqlite.prisma"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@casino/shared": "*",
    "@fastify/cookie": "^10.0.1",
    "@fastify/jwt": "^10.1.0",
    "@prisma/client": "^5.22.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.78.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.10.1",
    "otplib": "^13.4.1",
    "pino": "^9.5.0",
    "socket.io": "^4.8.3",
    "systeminformation": "^5.31.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.14.10",
    "@vitest/coverage-v8": "^3.2.6",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "pino-pretty": "^11.3.0",
    "prisma": "^5.22.0",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
