{
  "name": "virtual-casino-sandbox",
  "version": "0.1.0",
  "private": true,
  "description": "Virtual Casino Sandbox — npm workspaces monorepo (backend / frontend / admin-frontend / packages/shared)",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "backend",
    "frontend",
    "admin-frontend",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend,admin -c blue,green,magenta \"npm:dev:backend\" \"npm:dev:frontend\" \"npm:dev:admin\"",
    "dev:backend": "npm run dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:admin": "npm run dev --workspace=admin-frontend",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,vue,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,vue,json,md,yml,yaml}\"",
    "rtp:simulate": "tsx scripts/simulate-rtp.ts",
    "loadtest:spin": "k6 run scripts/loadtest/k6-spin.js",
    "loadtest:roulette": "k6 run scripts/loadtest/k6-roulette.js",
    "loadtest:mixed": "k6 run scripts/loadtest/k6-mixed.js",
    "test": "npm run test --workspace=backend",
    "test:coverage": "npm run test:coverage --workspace=backend",
    "test:security": "node scripts/security-attacks/run-all.js",
    "test:smoke": "node scripts/smoke-test.js"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.3.3",
    "tsx": "^4.16.2"
  },
  "overrides": {
    "fast-uri": "^3.1.2",
    "form-data": "^4.0.6",
    "ws": "^8.21.0"
  }
}
